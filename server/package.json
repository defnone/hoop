    "shared": "workspace:*",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
